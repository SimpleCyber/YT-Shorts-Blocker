{
  "manifest_version": 3,
  "name": "FocusShield: Content & Distraction Blocker",
  "version": "1.2",
  "description": "Reclaim your focus by blocking addictive short-form content.",
  "icons": {
    "48": "icon.png"
  },
  "permissions": [
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": ["timer.js", "content.js"],
      "css": ["timer.css", "styles.css"]
    }
  ]
}
