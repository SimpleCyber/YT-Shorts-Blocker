{
  "manifest_version": 3,
  "name": "NoDistract : Content & Distraction Blocker",
  "version": "1.3.1",
  "description": "Reclaim your focus and boost productivity by blocking addictive short-form content like YouTube Shorts and Instagram Reels.",
  "icons": {
    "48": "icon.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "idle",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": ["timer.js", "content.js"],
      "css": ["timer.css", "styles.css"]
    }
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  }
}
